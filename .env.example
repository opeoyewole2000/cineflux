# Get your free TMDB API key at: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# Get your Trakt API key at: https://trakt.tv/oauth/applications/new
VITE_TRAKT_CLIENT_ID=your_trakt_client_id_here
VITE_TRAKT_CLIENT_SECRET=your_trakt_client_secret_here
VITE_TRAKT_REDIRECT_URI=http://localhost:5173/trakt/callback
